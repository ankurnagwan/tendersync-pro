{
  "manifest_version": 3,
  "name": "GeM Tender Aggregator Engine",
  "short_name": "GEM Aggregator",
  "version": "2.0.0",
  "description": "Elite procurement intelligence engine for GeM Portal and TenderOnTime. Bypasses CORS, handles CAPTCHAs, and streams tender data to your dashboard.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png"
    },
    "default_title": "GeM Aggregator — Click to open status"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://gem.gov.in/*",
        "https://mkp.gem.gov.in/*"
      ],
      "js": ["utils/constants.js", "utils/dom_utils.js", "content.js"],
      "css": ["content_overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.tendersontime.com/*",
        "https://tendersontime.com/*"
      ],
      "js": ["utils/constants.js", "utils/dom_utils.js", "content.js"],
      "css": ["content_overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "webRequest",
    "cookies",
    "alarms",
    "notifications",
    "offscreen"
  ],

  "host_permissions": [
    "https://gem.gov.in/*",
    "https://mkp.gem.gov.in/*",
    "https://www.tendersontime.com/*",
    "https://tendersontime.com/*",
    "https://*.vercel.app/*",
    "http://localhost/*"
  ],

  "externally_connectable": {
    "matches": [
      "https://*.vercel.app/*",
      "http://localhost:5173/*",
      "http://localhost:3000/*",
      "http://localhost:4173/*",
      "http://127.0.0.1:5173/*",
      "http://127.0.0.1:3000/*",
      "http://127.0.0.1:4173/*"
    ]
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "utils/constants.js",
        "utils/dom_utils.js"
      ],
      "matches": [
        "https://gem.gov.in/*",
        "https://mkp.gem.gov.in/*",
        "https://tendersontime.com/*",
        "https://www.tendersontime.com/*"
      ]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "declarative_net_request": {
    "rule_resources": []
  }
}
