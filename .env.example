# ── GeM Aggregator Engine — Environment Variables Template ───────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# Google Gemini API Key (free at https://aistudio.google.com)
# Used by: /api/gemini.js (Vercel edge function for AI Executive Briefings)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Your Vercel deployment URL (set automatically by Vercel, no action needed)
# VERCEL_URL=gem-aggregator.vercel.app
